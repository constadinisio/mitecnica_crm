# Mi Tecnica CRM — frontend environment
# Copy to crm/.env and adjust for your environment.

APP_ENV=development
APP_URL=http://localhost:8080
API_BASE_URL=http://localhost:4000/api/v1
SESSION_NAME=mitecnica_crm_sess

# Enable to show the "Continue with Google" button on the login screen.
# Requires GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET in api/.env.
GOOGLE_OAUTH_ENABLED=false
