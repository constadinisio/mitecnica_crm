# Mi Tecnica CRM — API environment
# Copy to api/.env and adjust for your environment.

# Runtime
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
CRM_DB_HOST=127.0.0.1
CRM_DB_PORT=5432
CRM_DB_NAME=mitecnica_crm
CRM_DB_USER=mitecnica
CRM_DB_PASSWORD=mitecnica
CRM_DB_SSL=false

# JWT
JWT_SECRET=change-me-super-long-random-string
JWT_REFRESH_SECRET=change-me-another-super-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# CORS — comma-separated list of origins, or "*" to allow all (dev only)
CORS_ORIGIN=http://localhost:8080

# Google OAuth (optional — leave blank to keep disabled; never crashes the app)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_LOGIN_MAX=20

# Logging
LOG_LEVEL=info
